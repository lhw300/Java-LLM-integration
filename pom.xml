                    <target>
                        <echo message="正在执行极速拷贝..."/>
                        <copy file="target/lcallai-1.0.jar"
                              todir="E:/EIT/VR8/cont/lib"
                              overwrite="true"
                              failonerror="true"/>
                        <echo message="拷贝完成！"/>
                    </target>
                </configuration>
            </plugin>
        </plugins>
